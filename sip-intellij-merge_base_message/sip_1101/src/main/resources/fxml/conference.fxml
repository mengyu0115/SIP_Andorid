<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.image.ImageView?>

<!-- 会议界面 - 腾讯会议风格（深色主题） -->
<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.sip.client.ui.conference.ConferenceViewController"
            style="-fx-background-color: #1e1e1e;">

    <!-- 顶部标题栏 -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-background-color: linear-gradient(to bottom, #1a1a1a, #191919); -fx-padding: 12 20 12 20; -fx-border-color: #2a2a2a; -fx-border-width: 0 0 1 0;">
            <Label fx:id="lblConferenceTitle" text="会议室" style="-fx-text-fill: white; -fx-font-size: 17px; -fx-font-weight: bold;"/>
            <Label text="-" style="-fx-text-fill: #808080; -fx-font-size: 14px;"/>
            <Label text="进行中" style="-fx-text-fill: #4caf50; -fx-font-size: 14px; -fx-font-weight: bold;"/>
            <Label fx:id="lblConferenceTime" text="10:15 - 10:45" style="-fx-text-fill: #999999; -fx-font-size: 13px; -fx-padding: 4 10 4 10; -fx-background-color: #262626; -fx-background-radius: 4;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="lblParticipantCount" text="5 位参与者" style="-fx-text-fill: #b4b4b4; -fx-font-size: 13px; -fx-padding: 4 12 4 12; -fx-background-color: #262626; -fx-background-radius: 4;"/>
        </HBox>
    </top>

    <!-- 中间内容区域（视频网格 + 聊天）-->
    <center>
        <SplitPane dividerPositions="0.7" style="-fx-background-color: #1e1e1e;">

            <!-- 左侧：视频网格区域 -->
            <ScrollPane fitToWidth="true" fitToHeight="true" style="-fx-background-color: #1e1e1e; -fx-background: #1e1e1e;">
                <GridPane fx:id="videoGridPane" hgap="10" vgap="10" style="-fx-background-color: #1e1e1e; -fx-padding: 10;">
                    <!-- 视频窗口将动态添加到这里 -->
                </GridPane>
            </ScrollPane>

            <!-- 右侧：聊天面板 -->
            <VBox spacing="0" style="-fx-background-color: #2d2d2d; -fx-min-width: 300;">

                <!-- 聊天标题 -->
                <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-background-color: #232323; -fx-padding: 15;">
                    <Label text="💬 聊天" style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;"/>
                </HBox>

                <!-- 聊天消息区域 -->
                <ScrollPane fx:id="chatScrollPane" fitToWidth="true" VBox.vgrow="ALWAYS"
                           style="-fx-background-color: #282828; -fx-background: #282828;">
                    <VBox fx:id="chatMessagesBox" spacing="8" style="-fx-padding: 10; -fx-background-color: #282828;"/>
                </ScrollPane>

                <!-- 输入框 -->
                <VBox spacing="5" style="-fx-padding: 10; -fx-background-color: #2d2d2d;">
                    <TextField fx:id="chatInputField" promptText="输入消息..."
                              style="-fx-background-color: #373737; -fx-text-fill: white; -fx-prompt-text-fill: #808080; -fx-background-radius: 4; -fx-padding: 8 10 8 10; -fx-border-color: #464646; -fx-border-radius: 4;"/>
                    <Button fx:id="btnSendMessage" text="发送" onAction="#handleSendMessage"
                           style="-fx-background-color: #0096ff; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 4; -fx-cursor: hand; -fx-pref-width: 70; -fx-pref-height: 35;"/>
                </VBox>
            </VBox>
        </SplitPane>
    </center>

    <!-- 底部控制栏 -->
    <bottom>
        <HBox alignment="CENTER" spacing="20" style="-fx-background-color: #232323; -fx-padding: 15 30 15 30;">

            <!-- 左侧控制按钮组 -->
            <HBox alignment="CENTER" spacing="20" HBox.hgrow="ALWAYS">

                <!-- 麦克风按钮 -->
                <VBox fx:id="btnMicrophone" alignment="CENTER" spacing="5" onMouseClicked="#handleToggleMicrophone"
                      style="-fx-cursor: hand; -fx-background-radius: 8; -fx-padding: 8 15 8 15;">
                    <Label fx:id="lblMicIcon" text="🎤" style="-fx-font-size: 28px;"/>
                    <Label fx:id="lblMicText" text="麦克风" style="-fx-text-fill: #c8c8c8; -fx-font-size: 12px;"/>
                </VBox>

                <!-- 摄像头按钮 -->
                <VBox fx:id="btnCamera" alignment="CENTER" spacing="5" onMouseClicked="#handleToggleCamera"
                      style="-fx-cursor: hand; -fx-background-radius: 8; -fx-padding: 8 15 8 15;">
                    <Label fx:id="lblCameraIcon" text="📹" style="-fx-font-size: 28px;"/>
                    <Label fx:id="lblCameraText" text="摄像头" style="-fx-text-fill: #c8c8c8; -fx-font-size: 12px;"/>
                </VBox>

                <!-- 共享屏幕按钮 -->
                <VBox fx:id="btnScreenShare" alignment="CENTER" spacing="5" onMouseClicked="#handleToggleScreenShare"
                      style="-fx-cursor: hand; -fx-background-radius: 8; -fx-padding: 8 15 8 15;">
                    <Label fx:id="lblScreenIcon" text="🖥️" style="-fx-font-size: 28px;"/>
                    <Label fx:id="lblScreenText" text="共享屏幕" style="-fx-text-fill: #c8c8c8; -fx-font-size: 12px;"/>
                </VBox>

                <!-- 参与者按钮 -->
                <VBox alignment="CENTER" spacing="5" onMouseClicked="#handleShowParticipants"
                      style="-fx-cursor: hand; -fx-background-radius: 8; -fx-padding: 8 15 8 15;">
                    <Label text="👥" style="-fx-font-size: 28px;"/>
                    <Label text="参与者" style="-fx-text-fill: #c8c8c8; -fx-font-size: 12px;"/>
                </VBox>

                <!-- 设置按钮 -->
                <VBox alignment="CENTER" spacing="5" onMouseClicked="#handleSettings"
                      style="-fx-cursor: hand; -fx-background-radius: 8; -fx-padding: 8 15 8 15;">
                    <Label text="⚙️" style="-fx-font-size: 28px;"/>
                    <Label text="设置" style="-fx-text-fill: #c8c8c8; -fx-font-size: 12px;"/>
                </VBox>
            </HBox>

            <!-- 右侧：结束会议按钮 -->
            <Button fx:id="btnEndConference" text="结束会议" onAction="#handleEndConference"
                   style="-fx-background-color: #dc3545; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-background-radius: 4; -fx-cursor: hand; -fx-pref-width: 120; -fx-pref-height: 50;"/>
        </HBox>
    </bottom>

</BorderPane>
