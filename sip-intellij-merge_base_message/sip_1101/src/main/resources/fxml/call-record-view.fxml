<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.sip.client.ui.controller.CallRecordViewController"
            prefHeight="700.0" prefWidth="900.0"
            style="-fx-background-color: #f8f9fa;">

    <!-- 顶部标题栏 -->
    <top>
        <VBox style="-fx-background-color: white; -fx-border-color: #e5e5e5; -fx-border-width: 0 0 1 0;">
            <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-padding: 20;">
                <Label text="📞 通话记录" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                <Region HBox.hgrow="ALWAYS"/>

                <!-- 筛选器 -->
                <Label text="类型：" style="-fx-text-fill: #666;"/>
                <ComboBox fx:id="callTypeFilter" promptText="全部" prefWidth="120"
                         style="-fx-background-color: white; -fx-border-color: #ddd; -fx-border-radius: 4px;"/>

                <Button text="🔄 刷新" onAction="#handleRefresh"
                       style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-padding: 8 20; -fx-border-radius: 4px; -fx-background-radius: 4px;"/>
            </HBox>
        </VBox>
    </top>

    <!-- 中间表格区域 -->
    <center>
        <VBox style="-fx-padding: 20; -fx-background-color: #f8f9fa;">
            <TableView fx:id="callRecordTable" VBox.vgrow="ALWAYS"
                      style="-fx-background-color: white; -fx-border-color: #e5e5e5; -fx-border-radius: 4px; -fx-background-radius: 4px;">
                <columns>
                    <TableColumn fx:id="idColumn" text="ID" prefWidth="60"/>
                    <TableColumn fx:id="typeColumn" text="类型" prefWidth="80"/>
                    <TableColumn fx:id="callerColumn" text="发起者" prefWidth="120"/>
                    <TableColumn fx:id="calleeColumn" text="接收者" prefWidth="120"/>
                    <TableColumn fx:id="startTimeColumn" text="发起时间" prefWidth="180"/>
                    <TableColumn fx:id="endTimeColumn" text="结束时间" prefWidth="180"/>
                    <TableColumn fx:id="durationColumn" text="通话时长" prefWidth="100"/>
                    <TableColumn fx:id="statusColumn" text="状态" prefWidth="80"/>
                </columns>
                <placeholder>
                    <Label text="暂无通话记录" style="-fx-text-fill: #999; -fx-font-size: 14px;"/>
                </placeholder>
            </TableView>
        </VBox>
    </center>

    <!-- 底部分页和统计 -->
    <bottom>
        <VBox style="-fx-background-color: white; -fx-border-color: #e5e5e5; -fx-border-width: 1 0 0 0; -fx-padding: 15;">
            <HBox alignment="CENTER_LEFT" spacing="20">
                <Label fx:id="totalRecordsLabel" text="总记录数：0" style="-fx-text-fill: #666;"/>
                <Label fx:id="totalDurationLabel" text="总通话时长：0分钟" style="-fx-text-fill: #666;"/>

                <Region HBox.hgrow="ALWAYS"/>

                <!-- 分页控制 -->
                <Label text="每页：" style="-fx-text-fill: #666;"/>
                <ComboBox fx:id="pageSizeComboBox" value="20" prefWidth="80"
                         style="-fx-background-color: white; -fx-border-color: #ddd; -fx-border-radius: 4px;">
                </ComboBox>

                <Button text="上一页" fx:id="prevPageButton" onAction="#handlePrevPage"
                       style="-fx-background-color: #e9e9e9; -fx-text-fill: #333; -fx-padding: 6 15; -fx-border-radius: 4px; -fx-background-radius: 4px;"/>
                <Label fx:id="pageInfoLabel" text="第 1 页 / 共 1 页" style="-fx-text-fill: #666;"/>
                <Button text="下一页" fx:id="nextPageButton" onAction="#handleNextPage"
                       style="-fx-background-color: #e9e9e9; -fx-text-fill: #333; -fx-padding: 6 15; -fx-border-radius: 4px; -fx-background-radius: 4px;"/>
            </HBox>
        </VBox>
    </bottom>

</BorderPane>
