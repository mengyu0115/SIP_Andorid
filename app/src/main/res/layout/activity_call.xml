<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A2E">

    <!-- ===== 视频预览区域（视频通话时显示，语音通话时隐藏） ===== -->

    <!-- 远端视频（全屏底层，VideoEngine 解码 RTP H.264 后渲染到此 Surface） -->
    <SurfaceView
        android:id="@+id/surfaceRemoteVideo"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- 本地摄像头预览（右上角小窗） -->
    <SurfaceView
        android:id="@+id/surfaceLocalVideo"
        android:layout_width="120dp"
        android:layout_height="160dp"
        android:layout_marginTop="48dp"
        android:layout_marginEnd="16dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 对方用户名 -->
    <TextView
        android:id="@+id/tvRemoteUser"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="120dp"
        android:text="用户名"
        android:textColor="#FFFFFF"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 通话状态 -->
    <TextView
        android:id="@+id/tvCallStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="呼叫中..."
        android:textColor="#AAAACC"
        android:textSize="16sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvRemoteUser" />

    <!-- 通话计时 -->
    <TextView
        android:id="@+id/tvCallDuration"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="00:00"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvCallStatus" />

    <!-- 通话类型图标 -->
    <ImageView
        android:id="@+id/ivCallTypeIcon"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_marginTop="40dp"
        android:src="@android:drawable/ic_btn_speak_now"
        android:tint="#4FC3F7"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvCallDuration" />

    <!-- ===== 通话中控制按钮（静音 + 免提 + 切换摄像头） ===== -->
    <LinearLayout
        android:id="@+id/layoutControls"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/layoutCallButtons">

        <!-- 静音按钮 -->
        <LinearLayout
            android:id="@+id/btnMute"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_marginEnd="24dp"
            android:background="@android:color/transparent"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/ivMute"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@android:drawable/ic_lock_silent_mode_off"
                android:tint="#FFFFFF" />

            <TextView
                android:id="@+id/tvMute"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="静音"
                android:textColor="#FFFFFF"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- 免提按钮 -->
        <LinearLayout
            android:id="@+id/btnSpeaker"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_marginEnd="24dp"
            android:background="@android:color/transparent"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/ivSpeaker"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@android:drawable/ic_lock_silent_mode"
                android:tint="#FFFFFF" />

            <TextView
                android:id="@+id/tvSpeaker"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="免提"
                android:textColor="#FFFFFF"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- 切换摄像头按钮（仅视频通话时显示） -->
        <LinearLayout
            android:id="@+id/btnSwitchCamera"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:background="@android:color/transparent"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true"
            android:visibility="gone">

            <ImageView
                android:id="@+id/ivSwitchCamera"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@android:drawable/ic_menu_camera"
                android:tint="#FFFFFF" />

            <TextView
                android:id="@+id/tvSwitchCamera"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="翻转"
                android:textColor="#FFFFFF"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- ===== 底部通话按钮区域 ===== -->
    <LinearLayout
        android:id="@+id/layoutCallButtons"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="80dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- 拒接按钮（来电时显示） -->
        <LinearLayout
            android:id="@+id/btnReject"
            android:layout_width="72dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="60dp"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:padding="16dp"
                android:background="@android:drawable/presence_busy"
                android:src="@android:drawable/ic_menu_call"
                android:tint="#FFFFFF"
                android:rotation="135" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="拒接"
                android:textColor="#FF5252"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- 挂断按钮（始终显示） -->
        <LinearLayout
            android:id="@+id/btnHangup"
            android:layout_width="72dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:padding="12dp"
                android:src="@android:drawable/ic_menu_call"
                android:tint="#FFFFFF"
                android:rotation="135"
                android:backgroundTint="#FF5252"
                android:background="@android:drawable/btn_default" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="挂断"
                android:textColor="#FF5252"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- 接听按钮（来电时显示） -->
        <LinearLayout
            android:id="@+id/btnAccept"
            android:layout_width="72dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="60dp"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:padding="12dp"
                android:src="@android:drawable/ic_menu_call"
                android:tint="#FFFFFF"
                android:backgroundTint="#4CAF50"
                android:background="@android:drawable/btn_default" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="接听"
                android:textColor="#4CAF50"
                android:textSize="14sp" />
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
